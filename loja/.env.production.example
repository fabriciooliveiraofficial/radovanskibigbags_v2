# ======================================================================
# Radovanski Big Bags — configuração de PRODUÇÃO (Hostinger Cloud)
# Copie para ".env" no servidor e preencha os valores reais.
# ======================================================================

APP_NAME="Radovanski Big Bags"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://radovanskibigbags.com.br

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR
APP_TIMEZONE=America/Sao_Paulo

# --- Banco de dados MySQL (criado no painel da Hostinger) ---
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=000000_bigbags_db
DB_USERNAME=000000_bigbags_user
DB_PASSWORD=000000

# --- Sessão e cache (file = sem dependências extras; suficiente p/ este porte) ---
SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_STORE=file
# Use "sync" para enviar e-mails de forma síncrona/imediata sem precisar de daemon de fila.
# Se preferir usar filas em segundo plano com banco de dados, use "database" (requer rodar o queue worker).
QUEUE_CONNECTION=sync

# --- Log enxuto em produção ---
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=warning

# --- E-mail (SMTP da Hostinger — para futuros envios) ---
MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USERNAME=contato@radovanskibigbags.com.br
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS="contato@radovanskibigbags.com.br"
MAIL_FROM_NAME="${APP_NAME}"

# Os tokens de frete (Melhor Envio, SuperFrete, Frenet) e a chave do
# OpenRouteService são cadastrados pelo PAINEL ADMIN (Configurações da loja),
# não aqui — assim o cliente troca sem mexer em arquivo.
